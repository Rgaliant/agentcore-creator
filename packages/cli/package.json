{
  "name": "create-agentcore",
  "version": "0.1.0",
  "description": "Scaffold and manage AWS AgentCore agent platforms",
  "bin": {
    "create-agentcore": "./dist/create.js",
    "agentcore": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": ["dist", "templates"],
  "scripts": {
    "build": "tsc && chmod +x dist/create.js dist/index.js",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "picocolors": "^1.0.0",
    "@aws-sdk/client-cloudformation": "^3.600.0",
    "@aws-sdk/client-ssm": "^3.600.0"
  },
  "devDependencies": {
    "typescript": "*",
    "@types/node": "*"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
