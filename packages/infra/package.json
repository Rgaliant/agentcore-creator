{
  "name": "@agentcore/infra",
  "version": "0.1.0",
  "private": true,
  "description": "AWS CDK v2 infrastructure for agentcore-creator",
  "main": "bin/app.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf cdk.out dist",
    "synth": "cdk synth",
    "diff": "cdk diff",
    "deploy": "cdk deploy --require-approval never",
    "deploy:all": "cdk deploy --all --require-approval never",
    "destroy": "cdk destroy --all"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.150.0",
    "constructs": "^10.3.0",
    "@agentcore/shared": "workspace:*"
  },
  "devDependencies": {
    "aws-cdk": "^2.150.0",
    "typescript": "*"
  }
}
