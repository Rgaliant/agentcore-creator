# ============================================================
# AgentCore Creator — Environment Variables
# Copy this file to .env.local and fill in your values.
# Values marked (CDK output) are populated automatically by
# `agentcore deploy` after the CDK stacks are deployed.
# ============================================================

# ── AWS ─────────────────────────────────────────────────────
AWS_ACCOUNT_ID=123456789012
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Amazon Bedrock AgentCore (CDK output) ───────────────────
AGENTCORE_RUNTIME_ARN=
AGENTCORE_GATEWAY_URL=
AGENTCORE_MEMORY_ID=

# ── Bedrock Models ───────────────────────────────────────────
BEDROCK_DEFAULT_MODEL_ID=anthropic.claude-sonnet-4-5-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# ── Vercel Workflow DevKit ───────────────────────────────────
# Generate with: openssl rand -base64 32
WORKFLOW_SECRET=

# ── Vercel AI Gateway ────────────────────────────────────────
# From: https://vercel.com/dashboard → AI → Gateway
VERCEL_AI_GATEWAY_API_KEY=

# ── Discord Bot ──────────────────────────────────────────────
# Create app at: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
# Ed25519 public key for interaction signature verification
DISCORD_PUBLIC_KEY=

# ── GitHub App ───────────────────────────────────────────────
# Create app at: https://github.com/settings/apps/new
GITHUB_APP_ID=
# PEM key with newlines escaped as \n (single line)
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
# Default repo for the Q&A agent (format: org/repo)
GITHUB_DEFAULT_REPO=

# ── AWS SES / Email ──────────────────────────────────────────
SES_DOMAIN=mail.example.com
SES_FROM_ADDRESS=agent@example.com
# S3 bucket for inbound raw emails (CDK output)
SES_S3_BUCKET=

# ── DynamoDB Tables (CDK output) ─────────────────────────────
DYNAMODB_AGENT_CONFIGS_TABLE=
DYNAMODB_AGENT_RUNS_TABLE=
DYNAMODB_CONVERSATION_THREADS_TABLE=

# ── SQS Queues (CDK output) ──────────────────────────────────
SQS_DISCORD_QUEUE_URL=
SQS_EMAIL_INGEST_QUEUE_URL=

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional: set to "true" to enable Clerk auth integration
AUTH_PROVIDER=none
